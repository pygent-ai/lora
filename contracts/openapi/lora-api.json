{
  "components": {
    "schemas": {
      "ChatTurnRequest": {
        "properties": {
          "case_id": {
            "default": "chat",
            "title": "Case Id",
            "type": "string"
          },
          "message": {
            "minLength": 1,
            "title": "Message",
            "type": "string"
          },
          "session_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Session Id"
          },
          "turn_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Turn Id"
          }
        },
        "required": [
          "message"
        ],
        "title": "ChatTurnRequest",
        "type": "object"
      },
      "CreateSessionRequest": {
        "properties": {
          "case_id": {
            "default": "chat",
            "title": "Case Id",
            "type": "string"
          },
          "mode": {
            "default": "chat",
            "title": "Mode",
            "type": "string"
          }
        },
        "title": "CreateSessionRequest",
        "type": "object"
      },
      "DeleteResponse": {
        "properties": {
          "deleted": {
            "title": "Deleted",
            "type": "boolean"
          }
        },
        "required": [
          "deleted"
        ],
        "title": "DeleteResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
