          },
          "status": {
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status",
          "service"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "ProjectListResponse": {
        "properties": {
          "active": {
            "$ref": "#/components/schemas/ProjectResponse"
          },
          "projects": {
            "items": {
              "$ref": "#/components/schemas/ProjectResponse"
            },
            "title": "Projects",
            "type": "array"
          }
        },
        "required": [
          "active",
          "projects"
        ],
        "title": "ProjectListResponse",
        "type": "object"
