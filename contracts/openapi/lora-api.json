          },
          "created_at": {
            "title": "Created At",
            "type": "string"
          },
          "last_case_run_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Case Run Id"
          },
          "last_case_run_status": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Case Run Status"
          },
          "mode": {
            "title": "Mode",
            "type": "string"
          },
          "session_dir": {
            "title": "Session Dir",
            "type": "string"
          },
          "session_id": {
            "title": "Session Id",
            "type": "string"
          },
          "title": {
            "title": "Title",
            "type": "string"
          },
          "updated_at": {
            "title": "Updated At",
            "type": "string"
          }
        },
        "required": [
          "session_id",
          "session_dir",
          "case_id",
          "mode",
          "created_at",
          "updated_at",
          "title"
